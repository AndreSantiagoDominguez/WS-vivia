# Puerto HTTP/WebSocket del servicio de chat
PORT=3001

# Cadena de conexión a Postgres (mismo Postgres que el resto de Vivia)
DATABASE_URL=postgres://user:password@localhost:5432/vivia

# Secreto compartido con el backend Spring Boot (jwt.secret) — firma HS512
JWT_SECRET=

# Credenciales de Cloudinary (Dashboard → Account Details) para subir documentos
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
