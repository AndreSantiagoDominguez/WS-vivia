# Puerto HTTP/WebSocket del servicio de chat
PORT=3001

# Cadena de conexión a Postgres (mismo Postgres que el resto de Vivia)
DATABASE_URL=postgres://user:password@localhost:5432/vivia

# true solo contra bases accesibles por internet (p. ej. RDS) — Postgres local
# no expone SSL por default, dejar en false/vacío para desarrollo local.
DATABASE_SSL=false

# Máximo de conversaciones activas que un lessor FREE puede sostener (el cupo se
# consume cuando el lessor responde). Espejo de vivia.premium.free-property-limit.
CHAT_FREE_CONVERSATION_LIMIT=2

# Secreto compartido con el backend Spring Boot (jwt.secret) — firma HS512
JWT_SECRET=

# Credenciales de Cloudinary (Dashboard → Account Details) para subir documentos
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Base Postgres SEPARADA de DATABASE_URL donde vive users.fcm_token; SSL requerido
USERS_DATABASE_URL=postgres://user:password@host:5432/usersdb

# Ruta (fija) al service account JSON de Firebase Admin, montado como docker secret.
# El JSON en sí NO va aquí: se entrega como archivo (ver deploy.yml / compose.yml).
FIREBASE_KEY_PATH=/var/run/secrets/firebase-adminsdk.json
